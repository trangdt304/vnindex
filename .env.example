PORT=5173
DEFAULT_SYMBOL=GEX
WATCHLIST=GEX,FPT,HPG,VNM,VND
VNDIRECT_API_BASE=https://api-finfo.vndirect.com.vn/v4
# File SQLite. Có thể dùng đường dẫn tuyệt đối khi deploy.
SQLITE_PATH=./data/stock.db
# Giữ nguyên giá trị này sau khi deploy. Tạo bằng: openssl rand -hex 32
WATCHLIST_IP_SALT=
# Bảo vệ endpoint đồng bộ từ GitHub Actions/cron bên ngoài.
CRON_SECRET=
# Đặt 127.0.0.1 nếu dùng Caddy/Nginx trên cùng VM.
BIND_ADDRESS=0.0.0.0
# Gemini chỉ được gọi từ backend. Không đưa key vào public/app.js.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# Số lần tạo mới tối đa trên mỗi IP trong 10 phút; kết quả cache không bị tính.
AI_RATE_LIMIT=5
